@namespace NewUserSite.Components.Shared

<div id="@ModalId" class="confirm-modal @(IsVisible ? "show" : "")" role="dialog" aria-hidden="@(!IsVisible).ToString().ToLower()">
    <div class="confirm-backdrop" @onclick="Cancel"></div>
    <div class="confirm-dialog" role="document" @onclick:stopPropagation>
        <header class="confirm-header">
            <h5>@Title</h5>
            <button class="confirm-close" @onclick="Cancel" aria-label="Close">×</button>
        </header>

        <div class="confirm-body">
            @((MarkupString)Message)
        </div>

        <footer class="confirm-footer">
            <button class="btn btn-secondary" @onclick="Cancel">@CancelText</button>
            <button class="btn btn-danger" @onclick="ConfirmClicked">@ConfirmText</button>
        </footer>
    </div>
</div>

@code {
    [Parameter] public string ModalId { get; set; } = "confirm-modal";
    [Parameter] public string Title { get; set; } = "Confirm";
    [Parameter] public string Message { get; set; } = "Are you sure you want to delete? This cannot be undone.";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public string ConfirmText { get; set; } = "Delete";
    [Parameter] public EventCallback<int> OnConfirm { get; set; }

    private bool IsVisible { get; set; }
    private int _targetId;

    public Task Show(int id)
    {
        _targetId = id;
        IsVisible = true;
        return InvokeAsync(StateHasChanged);
    }

    public Task Hide()
    {
        IsVisible = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmClicked()
    {
        await OnConfirm.InvokeAsync(_targetId);
        await Hide();
    }

    private Task Cancel()
    {
        return Hide();
    }

}
