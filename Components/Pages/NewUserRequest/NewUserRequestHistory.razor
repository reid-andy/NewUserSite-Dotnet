@page "/new-user-request/history"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.EntityFrameworkCore
@using NewUserSite.Data
@using NewUserSite.Models
@using NewUserSite.Components.Shared
@inject IDbContextFactory<NewUserSite.Data.NewUserDbContext> dbContextFactory

<h1 class="mb-5">Request History</h1>

<div class="row mb-3">
    <div class="col-4">
        <div class="input-group">
            <input type="text" class="form-control border-primary" placeholder="Search by name" @bind="nameFilter" @bind:event="oninput" />
            <button type="button" class="btn btn-outline-secondary" @onclick="@clearSearchBox">Clear</button>
        </div>
    </div>
</div>

<QuickGrid Class="table" Items="filteredUsers.AsQueryable()" Pagination="pagination">
    <PropertyColumn Property="newUser => newUser.GetDisplayName()" Title="Name" />
    <PropertyColumn Property="newUser => newUser.ADOrganizationalUnit.Name" Title="@preferences.OrganizationalUnit" />
    <PropertyColumn Property="newUser => newUser.NewUserTemplate.TemplateName" Title="@preferences.Template" />
    <PropertyColumn Property="newUser => newUser.SupervisorEmail" Title="Supervisor Email Address"/>
    <PropertyColumn Property="newUser => newUser.CreatedBy" Title="Requested By"/>
    <PropertyColumn Property="newUser => newUser.RequestedDate" Title="Requested Date"/>
    <PropertyColumn Property="@(newUser => newUser.ApprovedDate.ToString() ?? "Not yet approved")" Title="Approved Date" />
    <PropertyColumn Property="@(newUser => newUser.ApprovedBy ?? "Not yet approved")" Title="Approved By"/>

    <TemplateColumn Context="newUser" Title="Actions">
        <a href="@($"/new-user-request/edit?id={newUser.Id}")" class="btn btn-warning py-1 my-1">Edit</a>
        @if (newUser.ApprovedBy is null)
        {
            <button class="btn btn-danger py-1 my-1" @onclick="() => confirmDelete(newUser.Id)">Delete</button>
        }
        else
        {
            <button class="btn btn-danger py-1 my-1" disabled>Delete</button>
        }
    </TemplateColumn>
</QuickGrid>
<Paginator State="pagination" />

<ConfirmModal @ref="confirmModal"
              ModalId="confirmDeleteModal"
              Title="Delete Request?"
              Message="Are you sure you want to delete this Request?"
              ConfirmText="Delete" OnConfirm="DeleteRequest" />

@code {
    private NewUserDbContext context = default!;
    private ConfirmModal? confirmModal;
    private List<NewUser> newUsers = new();
    private ApplicationPreferences preferences = new();
    private string nameFilter = string.Empty;
    PaginationState pagination = new PaginationState { ItemsPerPage = 25 };

    private List<NewUser> filteredUsers => newUsers
        .Where(n => string.IsNullOrEmpty(nameFilter) || n.GetDisplayName().Contains(nameFilter, StringComparison.OrdinalIgnoreCase))
        .ToList();


    protected override async Task OnInitializedAsync()
    {
        context = dbContextFactory.CreateDbContext();
        await LoadNewUsersAsync();
        preferences = await context.ApplicationPreferences.FirstOrDefaultAsync();
    }

    private async Task LoadNewUsersAsync()
    {
        newUsers = await context.NewUsers
            .Include(a => a.ADOrganizationalUnit)
            .Include(t => t.NewUserTemplate)
            .Include(d => d.Domain)
            .AsNoTracking()
            .OrderBy(n => n.RequestedDate)
            .ToListAsync();
    }

    private async Task confirmDelete(int Id)
    {
        if (confirmModal is not null)
        {
            await confirmModal.Show(Id);
        }
    }

    private async Task DeleteRequest(int Id)
    {
        var userToDelete = await context.NewUsers.FirstOrDefaultAsync(t => t.Id == Id);
        if (userToDelete is null) return;
        context.NewUsers.Remove(userToDelete);
        await context.SaveChangesAsync();

        await LoadNewUsersAsync();
        StateHasChanged();
    }

    private void clearSearchBox()
    {
        nameFilter = string.Empty;
        StateHasChanged();
    }

}
