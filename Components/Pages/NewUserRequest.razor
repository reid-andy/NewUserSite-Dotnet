@rendermode InteractiveServer
@page "/new-user-request"
@using NewUserSite.Models
@using NewUserSite.Data
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<NewUserSite.Data.NewUserDbContext> dbContextFactory

<h1>New User Request</h1>

<EditForm Model="@newUser" FormName="NewUserRequestForm" OnValidSubmit=@handleValidSubmit >
    <label for="FirstName">First Name:</label>
    <InputText id="FirstName" @bind-Value="@newUser.FirstName" />
    <label for="LastName">Last Name:</label>
    <InputText id="LastName" @bind-Value="@newUser.LastName" />

    <label for="ADOrganizationalUnit">ADOrganizationalUnit:</label>
    <select name="ADOrganizationalUnit" id="ADOrganizationalUnit" @onchange="OnOrganizationalUnitChanged">
        <option value="">--Select an OU--</option>
        @foreach (var ou in organizationalUnits)
        {
            <option value="@ou.Id">@ou.Name</option>
        }
        )
    </select>

    <label for="NewUserTemplate">Template:</label>
    <select name="NewUserTemplate" id="NewUserTemplate" @bind="@selectedTemplateId" disabled="@(availableTemplates.Count == 0)">
        <option value="">@(availableTemplates.Count == 0 ? "Select an OU first" : "--Select a template--")</option>
        @foreach (var template in availableTemplates)
        {
            <option value="@template.Id">@template.TemplateName</option>
        }
    </select>
    
    <button type="submit">Submit Request</button>
</EditForm>

@code {
    NewUser newUser = new NewUser();
    private NewUserDbContext context;
    private List<ADOrganizationalUnit> organizationalUnits = new();
    private int? selectedOuId;
    private int? selectedTemplateId;
    private List<NewUserTemplate> availableTemplates = new();

    protected override async Task OnInitializedAsync()
    {
        context = dbContextFactory.CreateDbContext();
        organizationalUnits = await context.ADOrganizationalUnits
            .Include(t => t.NewUserTemplates)
            .ToListAsync();
    }

    private void OnOrganizationalUnitChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out int ouId)) {
            selectedOuId = ouId;
            var selectedOu = organizationalUnits.FirstOrDefault(ou => ou.Id == ouId);
            availableTemplates = selectedOu?.NewUserTemplates.ToList() ?? new List<NewUserTemplate>();
        }
    }

    public async Task handleValidSubmit(EditContext editContext)
    {
        
    }
}
