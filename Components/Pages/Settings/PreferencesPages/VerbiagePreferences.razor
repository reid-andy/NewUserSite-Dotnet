@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using NewUserSite.Models
@using NewUserSite.Data
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<NewUserSite.Data.NewUserDbContext> dbContextFactory
@inject NavigationManager NavigationManager

<h2 class="mb-3">Verbiage Preferences</h2>

<div>
    <p>
        Here you can change the verbiage reflected on the new user request page if so desired.
    </p>
    <p>
        By default, these are set to terms that relate better for non-technical users.
    </p>
</div>

@if (preferences is null)
{
    <p>Loading preferences...</p>
}
else
{
    @if (editMode)
    {
        <EditForm Model="@preferences" FormName="PreferencesForm" OnValidSubmit="@handleValidSubmit">
            <div class="mb-3 fw-bold">
                <label for="OrganizationalUnit">Organizational Unit:</label>
                <InputText id="OrganizationalUnit" @bind-Value="@preferences.OrganizationalUnit" class="col-3" />
            </div>
            <div class="mb-3 fw-bold">
                <label for="Template">Template Account:</label>
                <InputText id="Template" @bind-Value="@preferences.Template" class="col-3" />
            </div>
            <div>
                <button type="submit" class="btn btn-primary">Save Preferences</button>
                <button type="button" class="btn btn-danger" @onclick="@toggleEdit">Cancel</button>
            </div>
        </EditForm>
    }
    else
    {
        <div class="mb-3 fw-bold">
            Organizational Unit: @preferences.OrganizationalUnit
        </div>
        <div class="mb-3 fw-bold">
            Template Account: @preferences.Template
        </div>
        <div>
            <button type="button" class="btn btn-warning" @onclick="@toggleEdit">Edit Verbiage</button>
        </div>
    }
}


@code {
    private ApplicationPreferences? preferences { get; set; }
    private bool editMode { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        using var context = dbContextFactory.CreateDbContext();
        preferences ??= await context.ApplicationPreferences.FirstOrDefaultAsync();
    }

    private async Task handleValidSubmit(EditContext editContext)
    {
        using var context = dbContextFactory.CreateDbContext();
        var updatedPreferences = (ApplicationPreferences)editContext.Model;
        context.ApplicationPreferences.Update(updatedPreferences);

        await context.SaveChangesAsync();
        toggleEdit();
    }

    private void toggleEdit()
    {
        if (editMode) { editMode = false; }
        else { editMode = true; }
        StateHasChanged();
    }

}
