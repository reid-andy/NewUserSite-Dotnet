@rendermode InteractiveServer
@page "/settings/roles/edit"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using NewUserSite.Models
@inject IDbContextFactory<NewUserSite.Data.NewUserDbContext> dbContextFactory
@inject NavigationManager NavigationManager

<h1>Edit Role</h1>

@if (userRole is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="@userRole" FormName="EditUserRole" OnValidSubmit="@UpdateUserRole">
        <div class="mb-3">
            <label for="Name">Active Directory Group Name:</label>
            <InputText id="Name" @bind-Value="@userRole.ADGroupName" class="col-3" />
        </div>
        <div class="mb-3">
            <label for="Role">Role:</label>
            <InputSelect name="Role" id="Role" @bind-Value="@userRole.Role">
                @foreach(var role in Enum.GetValues(typeof(Role)))
                {
                    <option value="@role">@role</option>
                }
            </InputSelect>
        </div>
        <div>
            <a href="/settings/roles" class="btn btn-secondary">Back</a>
            <button type="submit" class="btn btn-primary">Update Role</button>
        </div>
    </EditForm>
}

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    [SupplyParameterFromForm]
    private UserRole? userRole { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = dbContextFactory.CreateDbContext();
        userRole = await context.UserRoles.FirstOrDefaultAsync(r => r.Id == Id);

        if (userRole is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task UpdateUserRole()
    {
        if (userRole is not null)
        {
            using var context = dbContextFactory.CreateDbContext();
            context.UserRoles.Update(userRole);
            await context.SaveChangesAsync();
            NavigationManager.NavigateTo("/settings/roles");
        }
    }

}
