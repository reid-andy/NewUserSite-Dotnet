@page "/settings/domains"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.EntityFrameworkCore
@using NewUserSite.Components.Shared
@using NewUserSite.Models
@using NewUserSite.Data
@inject IDbContextFactory<NewUserSite.Data.NewUserDbContext> dbContextFactory
@inject NavigationManager NavigationManager


<h1>Domains</h1>

<a href="/settings/domains/add" class="btn btn-primary">Add a domain</a>

<QuickGrid Class="table" Items="domains.AsQueryable()">

    <PropertyColumn Class="text py-1" Property="domain => domain.Name" />

    <TemplateColumn Context="domain" Title="Actions">
        <a href="@($"/settings/domains/edit?id={domain.Id}")" class="btn btn-warning py-1 my-1">Edit</a>
        <button class="btn btn-danger py-1 my-1" @onclick="() => confirmDelete(domain.Id)">Delete</button>
    </TemplateColumn>

</QuickGrid>

<ConfirmModal @ref="confirmModal" 
    ModalId="confirmDeleteModal" 
    Title="Delete domain?" 
    Message="Are you sure you want to delete this Domain?"
    ConfirmText="Delete" OnConfirm="DeleteDomain" />

<a href="/settings" class="btn btn-secondary">Back</a>



@code {
    private NewUserDbContext context = default!;
    private ConfirmModal? confirmModal;
    private List<Domain> domains = new();

    protected override async Task OnInitializedAsync()
    {
        context = dbContextFactory.CreateDbContext();
        await LoadDomainsAsync();
    }

    private async Task LoadDomainsAsync()
    {
        domains = await context.Domains
            .AsNoTracking()
            .OrderBy(d => d.Name)
            .ToListAsync();
    }

    private async Task confirmDelete(int Id)
    {
        if (confirmModal is not null)
        {
            await confirmModal.Show(Id);
        }
    }

    private async Task DeleteDomain(int Id)
    {
        var domain = await context.Domains.FirstOrDefaultAsync(d => d.Id == Id);
        if (domain is null) return;
        context.Domains.Remove(domain);
        await context.SaveChangesAsync();

        await LoadDomainsAsync();
        StateHasChanged();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
