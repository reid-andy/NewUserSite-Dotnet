@page "/settings/template-accounts/edit"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using NewUserSite.Models
@using NewUserSite.Data
@using NewUserSite.Components.Shared
@using Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<NewUserSite.Data.NewUserDbContext> dbContextFactory
@inject NavigationManager NavigationManager

<h1>Edit Template Account</h1>

@if (newUserTemplate is null)
{
    <p>Loading...</p>
} else {

    <EditForm Model="@newUserTemplate" FormName="EditNewUserTemplate" OnValidSubmit="@UpdateNewUserTemplate">
        <div class="mb-3">
            <label for="TemplateName">Template Name:</label>
            <InputText id="TemplateName" @bind-Value="@newUserTemplate.TemplateName" class="col-3" />
            <label for="TemplateSAMAccountName" class="ms-2">SAM Account Name:</label>
            <InputText id="TemplateSAMAccountName" @bind-value="@newUserTemplate.TemplateSAMAccountName" class="col-3" />
        </div>

        <div>
            @if (ouCheckboxes?.Count > 0)
            {
                @foreach (var item in ouCheckboxes)
                {
                    <div class="input-group input-group-lg">
                        <InputCheckbox id="@($"ou-{item.OU.Id}")" @bind-Value="item.IsChecked" class="form-check-input me-2 mt-2" />
                        <label for=" "@($"ou-{item.OU.Id}")" class="fs-5">@item.OU.Name</label>
                    </div>
                }
            }
        </div>

        <div class="mt-3">
            <a href="/settings/template-accounts" class="btn btn-secondary">Back</a>
            <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
    </EditForm>

}

<ConfirmModal @ref="confirmModal"
              ModalId="confirmDeleteModal"
              Title="Delete Template?"
              Message="Are you sure you want to delete this Template?"
              ConfirmText="Delete" OnConfirm="DeleteTemplate" />

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }
    private NewUserDbContext context = default!;
    private NewUserTemplate? newUserTemplate;
    private List<ADOrganizationalUnit> organizationalUnits = new();
    private List<ADOrganizationalUnit> currentOrganizationalUnits = new();
    private ConfirmModal? confirmModal;
    private bool isSelected = false;

    private class OuCheckbox
    {
        public ADOrganizationalUnit OU { get; set; } = default!;
        public bool IsChecked { get; set; }
    }
    private List<OuCheckbox> ouCheckboxes = new();

    protected override async Task OnInitializedAsync()
    {
        context = dbContextFactory.CreateDbContext();
        newUserTemplate = await context.NewUserTemplates
            .Include(t => t.ADOrganizationalUnits)
            .FirstOrDefaultAsync(t => t.Id == Id);
        organizationalUnits = await context.ADOrganizationalUnits
            .ToListAsync();

        if (newUserTemplate is not null)
        {
            var associatedIds = new HashSet<int>(newUserTemplate.ADOrganizationalUnits.Select(o => o.Id));
            ouCheckboxes = organizationalUnits
                .Select(ou => new OuCheckbox
                    {
                        OU = ou,
                        IsChecked = associatedIds.Contains(ou.Id)
                    })
                .ToList();
        }
    }

    private async Task UpdateNewUserTemplate()
    {
        if (newUserTemplate is null) return;

        if (newUserTemplate is not null)
        {
            using var ctx = dbContextFactory.CreateDbContext();
            var templateToUpdate = await ctx.NewUserTemplates
                .Include(t => t.ADOrganizationalUnits)
                .FirstOrDefaultAsync(t => t.Id == newUserTemplate.Id);

            if (templateToUpdate is null) return;

            templateToUpdate.TemplateName = newUserTemplate.TemplateName;
            templateToUpdate.TemplateSAMAccountName = newUserTemplate.TemplateSAMAccountName;
            templateToUpdate.ADOrganizationalUnits.Clear();

            var selectedOuIds = ouCheckboxes.Where(ou => ou.IsChecked).Select(x => x.OU.Id).ToList();
            if (selectedOuIds.Count > 0)
            {
                var selectedOus = await ctx.ADOrganizationalUnits
                    .Where(ou => selectedOuIds.Contains(ou.Id))
                    .ToListAsync();

                foreach (var ou in selectedOus)
                {
                    templateToUpdate.ADOrganizationalUnits.Add(ou);
                }
            }

            ctx.NewUserTemplates.Update(templateToUpdate);
            await ctx.SaveChangesAsync();
            NavigationManager.NavigateTo("/settings/template-accounts");
        }
    }

    private async Task confirmDelete(int Id)
    {
        if (confirmModal is not null)
        {
            await confirmModal.Show(Id);
        }
    }

    private async Task DeleteTemplate(int Id)
    {
        var newUserTemplate = await context.NewUserTemplates.FirstOrDefaultAsync(t => t.Id == Id);
        if (newUserTemplate is null) return;
        context.NewUserTemplates.Remove(newUserTemplate);
        await context.SaveChangesAsync();

        NavigationManager.NavigateTo("/settings/template-accounts");
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
